# =========================================================
# Patiyolu — Environment Variables
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur.
# .env.local asla commit edilmez (.gitignore'da).
# =========================================================

# --- Supabase ---
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Sadece server-side, ASLA client'a sızdırma

# --- Mapbox ---
# https://account.mapbox.com → Tokens. Sadece domain restriction'lı public token client'a verilir.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# --- Iyzico ---
# https://merchant.iyzipay.com → Settings → API Keys
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com   # Production: https://api.iyzipay.com
IYZICO_WEBHOOK_SECRET=your-webhook-shared-secret

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Patiyolu

# --- Sentry (Faz 2'de aktive olur) ---
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
